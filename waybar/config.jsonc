// Waybar Configuration - Minimalist Catppuccin Mocha
{
    "layer": "top",
    "position": "top",
    "height": 38,
    "spacing": 4,
    "margin-top": 4,
    "margin-left": 12,
    "margin-right": 12,

    // Choose the order of modules
    "modules-left": [
        "hyprland/workspaces",
        "group/launchers"
    ],
    "modules-center": [
        "wlr/taskbar"
    ],
    "modules-right": [
        "group/status",
        "group/hardware",
        "clock",
        "tray",
        "custom/power"
    ],

    // Modules configuration
    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{icon}",
        "format-icons": {
            "active": "’äæ",
            "default": "’äī"
        }
    },

    "hyprland/window": {
        "format": " {title} ",
        "max-length": 40,
        "separate-outputs": true
    },

    "tray": {
        "icon-size": 18,
        "spacing": 10
    },

    "clock": {
        "timezone": "auto",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format": "’ĆŚ  {:%H:%M  ¾░āŁ  %d/%m}",
        "format-alt": "’ĆŚ  {:%H:%M:%S  ¾░āŁ  %Y-%m-%d}"
    },

    "cpu": {
        "format": "’Æ╝  {usage}%",
        "tooltip": true,
        "interval": 2
    },

    "memory": {
        "format": "Ņē”  {used:0.1f}G/{total:0.1f}G",
        "tooltip": true,
        "interval": 2
    },

    "network": {
        "format-wifi": "’ć½   {essid} ({signalStrength}%)",
        "format-ethernet": "¾░łĆ   {ipaddr}",
        "format-disconnected": "¾░¢¬   Desconectado",
        "tooltip-format": "Interfaz: {ifname}\nIP: {ipaddr}/{cidr}\nPuerta de enlace: {gwaddr}",
        "on-click": "kitty -e nmtui"
    },

    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon}  {volume}%",
        "format-muted": "¾░Ø¤  Silenciado",
        "format-icons": {
            "default": ["’Ć”", "’Ć¦", "’Ć©"]
        },
        "on-click": "pavucontrol"
    },

    "custom/power": {
        "format": "ŌÅ╗ ",
        "tooltip": false,
        "on-click": "/home/joseph/.local/bin/powermenu.sh"
    },

    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 20,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "all-outputs": true
    },

    "custom/launch-kitty": {
        "format": "’Æē ",
        "tooltip": false,
        "on-click": "kitty"
    },

    "custom/launch-dolphin": {
        "format": "¾░ēŗ ",
        "tooltip": false,
        "on-click": "dolphin"
    },

    "custom/launch-browser": {
        "format": "’Æä ",
        "tooltip": false,
        "on-click": "brave || firefox || chromium"
    },

    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}   {capacity}%",
        "format-charging": "’ć”   {capacity}%",
        "format-plugged": "’ć”   {capacity}%",
        "format-alt": "{icon}   {time}",
        "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"]
    },

    "group/launchers": {
        "orientation": "horizontal",
        "modules": [
            "custom/launch-kitty",
            "custom/launch-dolphin",
            "custom/launch-browser"
        ]
    },

    "group/status": {
        "orientation": "horizontal",
        "modules": ["network", "pulseaudio", "battery"]
    },

    "group/hardware": {
        "orientation": "horizontal",
        "modules": ["cpu", "memory"]
    }
}

# ==========================================
# Dunst Configuration - Catppuccin Mocha Theme
# Modern & Elegant Notifications
# ==========================================

[global]
    monitor = 0
    follow = mouse
    
    # Position & Size
    width = 300
    height = 110
    origin = top-right
    offset = 12x48 # Fits nicely below the Waybar
    scale = 0
    notification_limit = 5

    # Progress bar styling
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300

    indicate_hidden = yes
    transparency = 0
    separator_height = 2
    padding = 12
    horizontal_padding = 12
    text_icon_padding = 10
    frame_width = 2
    
    # Default Catppuccin Mocha colors
    frame_color = "#cba6f7" # Mauve
    separator_color = "#313244" # Surface

    # Font
    font = JetBrainsMono Nerd Font 10
    line_height = 0
    markup = full
    
    # Format: Bold summary + body
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_age_threshold = 60
    ellipsize = middle
    ignore_newline = no
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators = yes

    # Icons
    icon_position = left
    min_icon_size = 32
    max_icon_size = 48
    
    # Corner radius for matching the Waybar look
    corner_radius = 8

    # Mouse actions
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#1e1e2e" # Base
    foreground = "#cdd6f4" # Text
    frame_color = "#89b4fa" # Blue
    timeout = 8

[urgency_normal]
    background = "#1e1e2e" # Base
    foreground = "#cdd6f4" # Text
    frame_color = "#cba6f7" # Mauve
    timeout = 10

[urgency_critical]
    background = "#1e1e2e" # Base
    foreground = "#cdd6f4" # Text
    frame_color = "#f38ba8" # Red
    timeout = 0
